{
  "name": "@flashdot/coordinator",
  "version": "0.0.1",
  "private": true,
  "description": "FlashDot coordinator service — automates async multi-chain loan lifecycle",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "test": "vitest run",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "polkadot-api": "^1.23.3",
    "ethers": "^6.12.1",
    "drizzle-orm": "^0.45.1",
    "better-sqlite3": "^9.6.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^20.12.12",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
