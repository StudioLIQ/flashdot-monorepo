# FlashDot Coordinator — Environment Variables

# EVM RPC endpoints
HUB_RPC_URL=http://127.0.0.1:9945
VAULT_A_RPC_URL=http://127.0.0.1:9947
VAULT_B_RPC_URL=http://127.0.0.1:9949

# WebSocket for Hub events
HUB_WS_URL=ws://127.0.0.1:9946

# Deployed contract addresses
HUB_ADDRESS=0x...
VAULT_A_ADDRESS=0x...
VAULT_B_ADDRESS=0x...

# Coordinator private key (used to sign coordinator calls — permissionless on-chain)
COORDINATOR_PRIVATE_KEY=0xe5be9a5092b81bca64be81d212e7f2f9eba183bb7a90954f7b76361f6edb5c0a

# Database
DB_PATH=./coordinator.db
COORDINATOR_PORT=8787

# Retry config
MAX_RETRIES=5
RETRY_DELAYS_MS=1000,2000,5000,15000,60000

# Timeouts
PREPARE_TIMEOUT_MS=120000
COMMIT_TIMEOUT_MS=120000
DEFAULT_CHECK_INTERVAL_MS=10000
