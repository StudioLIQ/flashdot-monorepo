VAULT_B_RPC_URL=

# FlashDotHub deploy args
XCM_EXECUTOR=0x0000000000000000000000000000000000000800
FEE_RECIPIENT=0x0000000000000000000000000000000000000000
XCM_PRECOMPILE_ADDRESS=0x0000000000000000000000000000000000000800
SUPPORTED_CHAINS=parachain-2000,parachain-2001

# FlashDotVault deploy args
ASSET_ADDRESS=0x0000000000000000000000000000000000000000
HUB_SOVEREIGN_ACCOUNT=0x0000000000000000000000000000000000000000

# Optional mock token deploy args
TOKEN_NAME=Wrapped DOT
TOKEN_SYMBOL=wDOT
TOKEN_DECIMALS=18
